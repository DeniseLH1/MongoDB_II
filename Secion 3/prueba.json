//Primero:
// Creamos la base de datos llmada acme_store
use acme_store

// Luego 
// Insertamos datos de products invoices y clientes 
// Por ejemplo:
db.invoices.insertMany(
    //aqui el archivo json llamado invoices
)

// Ejercicios usando match: 

db.products.aggregate([
    {$match:{
        category: "Almacenamiento"
    }}
]);

//facturas del cliente con el siguiente id:15024445
db.invoices.aggregate([
  { $match: {
    "client.id": 15024445
  }}
]); 

//traer todos los facturas con el producto con el codigo p3
db.invoices.aggregate([
  { $match: {
    "items.code": "P003"
  }}
]);

//contar productos hay por categoria dentro de la colleccion productos
// nos permite sumas promedios conteos etc 
db.products.aggregate([
    {$group:{
        //para agrupar hay que usar un atributo en particular para agrupar
        _id: "$category",
        count: {$sum:1}
    }}
]);

//buscar cunatos clientes hay por cada ciudad de colombia 
db.clients.aggregate([
    {$group:{
        _id: "$location.city",
        count: {$sum:1}
    }}
]);

//productos sacar promedio de precios por cada categoria de productos que esten activos
db.products.aggregate([
    { $match: { active: true }},
    { $group: {
        _id: "$category",
        promedio: { $avg: "$price" }
    }}
]);

//uso de project: crea campos que no existan etc
db.clients.aggregate([
    {$group:{
        _id: "$location.city",
        count: {$sum:1}
    }},
    {$project:{
		_id:0,
        ciudad: "$_id",
        cantidadPersonas:"$count"
    }}
]);

//mostrar la cantidad de facturas por clientes las cuales tengan menos de 3 items
  db.invoices.aggregate([
    {
        //agrega nuevo campo al documento pueden ser calculados o no calculados size calcula el tamaño de los documentos eso agrega al final d ecada elemento 
      $addFields: {
        numItems: { $size: "$items" }
      }
    },
    //copn match esta filtrando docuemntos que tienen menos de 3 items
    {
      $match: {
        numItems: { $lt: 3 }
      }
    },
    
    {
      $group: {
        _id: "$client",
        totalFacturas: { $sum: 1 }
      }
    },
    {$project:{
        _id:0,
        client:"$_id.name",
        totalFacturas:1
    }}
  ]);

        //ejercicio simplificado para mostrar factura de clientes que tengan menos de 3 items
        db.invoices.aggregate([{
          $project: { client: "$client.name", numFacts: { $size: "$items" }}
        },
        { $match: { numFacts: { $lt: 3 }}},
        { $group: { _id: "$client", totalFacturas: { $sum: 1 }}},
        { $project: { _id: 0, client: "$_id", totalFacturas: 1}}
        ]);
 

//mostrar los clientes con mas de 5 facturas
db.invoices.aggregate([{
    $project:{
        client:"$client.name",
        numFacts:{$size:"$items"}
    }
  }])

//uso de sort 
db.invoices.aggregate([{
    $project: { client: "$client.name", numFacts: { $size: "$items" }}
  },
  { $match: { numFacts: { $lt: 3 }}},
  { $group: { _id: "$client", totalFacturas: { $sum: 1 }}},
  { $project: { _id: 0, client: "$_id", totalFacturas: 1}},
  { $sort: {client:1,totalFacturas:-1}}
  ]);

//uso de limit
db.invoices.aggregate([
    {$skip:5},
    {$limit:3}
]);

//-1 es para que sea acendente
db.products.aggregate([
    {$match:{active:true}},
    {$sort:{price:-1}},
    {$limit:5}
]);

//uso de min y max
db.products.aggregate([
    {$group:{
        _id:null,
        minPrice:{ $min: "$price"},
        maxPrice:{ $max: "$price"}
    }}
]);

//
db.products.aggregate([
    {$group:{
        _id:"$category",
        minPrice:{ $min: "$price"},
        maxPrice:{ $max: "$price"}
    }}
])

//uso de avg
db.products.aggregate([
    {$group:{
        _id:"$category",
        promedioPrice:{ $avg: "$price"}
    }}
]);

// clientes que menos han comprado en sentido monetario 
  //pasos para organizar tareas: analizar lo que se me esta pidiendo, ubicar donde estan los datos que se me solicita, analizar todo mi contexto, analizar que es lo que me falta 
  db.invoices.aggregate([
    {$match:{"invoiceNumber": "FACT-0001"}},
    {$unwind: "$items"}
  ])
  //para este ejecicio usaremos unwind el cual trabaja sobre arreglos lo que hace es seroparar los elementos. 
  //unwind va a trabajar con 1 documento este desglozara el arreglo en diferentes docuemntos convierte arreglos ene subdocumento
  // crea un docuemnto por cada item 
  db.invoices.aggregate([
    {$match:{"invoiceNumber": "FACT-0001"}},
    {$unwind: "$items"},
    {$project:{
      invoiceNUmber:1,
      totalItem:{$multiply:["$items.price","$items.cantidad"]}}}
  ])
//buscar total de un cliente
  db.invoices.aggregate([
    {$match:{"invoiceNumber": "FACT-0001"}},
    {$unwind: "$items"},
    {$group:{
      _id: {clientId: "$client.id",clientName:"$client.name"},
      totalFacturado:{$sum:{$multiply:["$items.price","$items.cantidad"]}}
    }}
  ])

//buscar total por todos los clientes 
db.invoices.aggregate([
  {$unwind: "$items"},
  {$group:{
    _id: {clientId: "$client.id",clientName:"$client.name"},
    totalFacturado:{$sum:{$multiply:["$items.price","$items.cantidad"]}}
  }}
])

//3 clientes que menos han comprado en sentido monetario 
db.invoices.aggregate([
  {$unwind: "$items"},
  {$group:{
    _id: {clientId: "$client.id",clientName:"$client.name"},
    totalFacturado:{$sum:{$multiply:["$items.price","$items.cantidad"]}}
  }},
  {$sort:{totalFacturado:1}},
  {$limit:3},
  //esto se lo puedes quitar o dejarlo
  {$project:{
    _id:0,
    clientId:"$_id.clientId",
    clientName:"$_id.clientName",
    totalFacturado:1
  }}
])
  
//otra forma
db.invoices.aggregate([
  { $unwind: "$items"},
  { $group: {
      _id: { clientId: "$client.id", clientName: "$client.name" },
      totalFacturado: { $sum: { $multiply: [ "$items.price", "$items.cantidad" ]}}
  }},
  { $sort: { totalFacturado: 1 }},
  { $limit: 3 },
  { $project: {
    _id: 0,
    //para convertir a texto se usa to string
    cliente: { $concat: [ { $toString: "$_id.clientId" }, ' - ', "$_id.clientName" ]},
    totalFacturado: 1
  }}
]);

